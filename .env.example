# ── FileVault Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

NODE_ENV=production
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://filevault:CHANGE_ME@localhost:5432/filevault
POSTGRES_USER=filevault
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=filevault-data

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_ME_32_CHARS_MIN

# JWT (use: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# App public URL — used in password reset links
# Set to your domain once you have one, or your server's IP+port
APP_URL=http://192.168.86.128:8080

# ── SMTP Email (optional — for forgot password emails) ────────────────────────
# Gmail: use App Password (https://myaccount.google.com/apppasswords)
# Resend: SMTP_HOST=smtp.resend.com  SMTP_USER=resend  SMTP_PASS=re_xxxx
# Mailgun: SMTP_HOST=smtp.mailgun.org
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FileVault <noreply@yourdomain.com>

# Limits
UPLOAD_MAX_SIZE_MB=5120

# Observability
GRAFANA_PASSWORD=CHANGE_ME
