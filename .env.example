# Copy to .env and fill in all values before first run.
# Never commit .env to source control.

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Set DATABASE_URL to point at an external Postgres host (e.g. 192.168.86.128)
# When using an external Postgres, comment out the 'postgres' service in docker-compose.yml
DATABASE_URL=postgresql://filevault:filevault_secret@192.168.86.128:5432/filevault
POSTGRES_USER=filevault
POSTGRES_PASSWORD=filevault_secret

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ── Meilisearch ───────────────────────────────────────────────────────────
MEILI_MASTER_KEY=change_me_32_char_meili_master_key

# ── JWT ───────────────────────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=change_me_very_long_jwt_secret_key
JWT_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────
PUBLIC_URL=https://files.yourdomain.com
UPLOAD_MAX_SIZE_MB=5120

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password
